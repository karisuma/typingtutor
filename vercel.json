{
    "redirects": [
        {
            "source": "/mobility",
            "destination": "/mobility/",
            "permanent": false
        }
    ],
    "rewrites": [
        {
            "source": "/",
            "destination": "/src/index.html"
        },
        {
            "source": "/mobility/:path*",
            "destination": "/src/mobility/:path*"
        },
        {
            "source": "/admin",
            "destination": "/admin/index.html"
        },
        {
            "source": "/admin/",
            "destination": "/admin/index.html"
        },
        {
            "source": "/profile",
            "destination": "/pages/profile.html"
        },
        {
            "source": "/profile/",
            "destination": "/pages/profile.html"
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=0, must-revalidate"
                }
            ]
        }
    ]
}
